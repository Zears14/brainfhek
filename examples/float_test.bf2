#include "stdlib"

fn main() -> i32 {
    f64 d = 10.5
    f32 f = 2.0
    i32 i = 5
    
    // Test mixed arithmetic
    f64 res1 = d + f     // 10.5 + 2.0 = 12.5
    f64 res2 = res1 * i  // 12.5 * 5 = 62.5
    
    "res1 (12.5): " .s
    res1 .f
    
    "res2 (62.5): " .s
    res2 .f
    
    // Test coercion
    i64 i_from_f = res2   // 62.5 -> 62
    "i64 from f (62): " .s
    i_from_f .i64
    
    ret 0
}
